# OpenAI API — usado nas rotas api/explain e api/evaluate (M2)
OPENAI_API_KEY=

# Supabase — persistência (M3). Acesso ao banco é só server-side:
# RLS ligado sem policies, então a chave pública (anon) não serve aqui.
# Settings → API do projeto: Project URL + service_role key (secret).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fuso horário: fixo em America/Sao_Paulo direto no código (lib/sm2.ts,
# app/(dashboard)/page.tsx) via Intl.DateTimeFormat — `TZ` é nome de env var
# reservado na Vercel, não dá pra configurar por env var lá.
